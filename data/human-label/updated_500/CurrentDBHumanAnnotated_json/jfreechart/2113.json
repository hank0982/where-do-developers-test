  "body": "@Test\n    public void testCloning() throws CloneNotSupportedException {\n        VectorDataItem v1 = new VectorDataItem(1.0, 2.0, 3.0, 4.0);\n        VectorDataItem v2 = CloneUtils.clone(v1);\n        assertNotSame(v1, v2);\n        assertSame(v1.getClass(), v2.getClass());\n        assertEquals(v1, v2);\n    }",
