  "body": "@Test\n    void testAddArgumentsWithQuotes() {\n        final CommandLine cmdl = new CommandLine(\"test\");\n        cmdl.addArguments(\"'foo' \\\"bar\\\"\");\n        assertEquals(\"[test, foo, bar]\", cmdl.toString());\n        assertArrayEquals(new String[] { \"test\", \"foo\", \"bar\" }, cmdl.toStrings());\n    }",
