  "body": "@SuppressWarnings(\"resource\")\n    @Test\n    void testAvailableAfterClose() throws Exception {\n        final InputStream shadow;\n        try (InputStream in = createInputStream()) {\n            assertTrue(in.available() > 0);\n            shadow = in;\n        }\n        assertEquals(0, shadow.available());\n    }",
