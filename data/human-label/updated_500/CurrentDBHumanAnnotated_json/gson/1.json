  "body": "@Test\n  public void testParseComments() {\n    String json =\n        \"[\\n\"\n            + \"  // this is a comment\\n\"\n            + \"  \\\"a\\\",\\n\"\n            + \"  /* this is another comment */\\n\"\n            + \"  \\\"b\\\",\\n\"\n            + \"  # this is yet another comment\\n\"\n            + \"  \\\"c\\\"\\n\"\n            + \"]\";\n\n    List<String> abc = new Gson().fromJson(json, new TypeToken<List<String>>() {}.getType());\n    assertThat(abc).containsExactly(\"a\", \"b\", \"c\").inOrder();\n  }",
