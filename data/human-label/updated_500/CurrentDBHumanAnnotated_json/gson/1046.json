  "body": "@Test\n  public void testContainsNullKeyIsAlwaysFalse() {\n    LinkedTreeMap<String, String> map = new LinkedTreeMap<>();\n    assertThat(map.containsKey(null)).isFalse();\n    map.put(\"a\", \"android\");\n    assertThat(map.containsKey(null)).isFalse();\n  }",
