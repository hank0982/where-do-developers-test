  "test_name": "testMapSize",
  "body": "@Test\n    void testMapSize() {\n        resetEmpty();\n        assertEquals(0, getMap().size(), \"Map.size() should be 0 with an empty map\");\n        verify();\n\n        resetFull();\n        assertEquals(getSampleKeys().length, getMap().size(), \"Map.size() should equal the number of entries in the map\");\n        verify();\n    }",
