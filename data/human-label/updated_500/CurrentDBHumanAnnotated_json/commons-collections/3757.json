  "body": "@Test\n    void testEntrySetContains2() {\n        resetFull();\n        final Set<Map.Entry<K, V>> entrySet = getMap().entrySet();\n        final Map.Entry<K, V> entry = entrySet.iterator().next();\n        final Map.Entry<K, V> test = cloneMapEntry(entry);\n        assertTrue(entrySet.contains(test));\n    }",
