  "test_name": "testMapIsEmpty",
  "body": "@Test\n    void testMapIsEmpty() {\n        resetEmpty();\n        assertTrue(getMap().isEmpty(), \"Map.isEmpty() should return true with an empty map\");\n        verify();\n\n        resetFull();\n        assertFalse(getMap().isEmpty(), \"Map.isEmpty() should return false with a non-empty map\");\n        verify();\n    }",
